      && sortedDryMassKoreanLabels.join("|") === "가가|나나|다다"
      && alphaMatches.length === 1
      && alphaMatches[0] === "Alpha"
      && hiddenMatches === 0
      && restoredSearchCount === expectedRestoredSearchCount;

